    }

    .debts_table {
        width: 100%;
        border-collapse: collapse;
    }

        .debts_table th, .debts_table td {
            border: 1px solid #ddd;
            padding: 10px;
            text-align: left;
        }

        .debts_table th {
            background-color: #f1f1f1;
        }
</style>