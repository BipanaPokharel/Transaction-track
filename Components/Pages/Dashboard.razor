    }

        .filter_btn:hover, .refresh_btn:hover {
            background-color: #f05a5a;
        }

    .refresh_btn {
        background-color: #60A5FA;
    }

        .refresh_btn:hover {
            background-color: #3B82F6;
        }

    .debug_section {
        margin: 20px 0;
        padding: 15px;
        background-color: #fff;
        border: 1px solid #ddd;
        border-radius: 8px;
    }

        .debug_section h3 {
            color: #666;
            margin-bottom: 10px;
        }

        .debug_section ul {
            list-style: none;
            padding: 0;
        }

        .debug_section li {
            padding: 8px 0;
            border-bottom: 1px solid #eee;
        }

    .statistics_overview {
        margin-top: 30px;
        background-color: #fff;
